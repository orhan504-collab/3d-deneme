<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.sketch3d.MyGLSurfaceView
        android:id="@+id/myGLSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/menusContainer" />

    <LinearLayout
        android:id="@+id/menusContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <HorizontalScrollView
            android:id="@+id/detailToolbar"
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="#2C2C2C"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="8dp">

                <LinearLayout style="@style/DetailButtonStyle">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_add" />
                    <TextView style="@style/DetailTextStyle" android:text="Yüzey oluştur" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btnMerge" style="@style/DetailButtonStyle">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_share" />
                    <TextView style="@style/DetailTextStyle" android:text="Birleştir" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btnTargetWeld" style="@style/DetailButtonStyle">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_send" />
                    <TextView style="@style/DetailTextStyle" android:text="Hedef birleştirme" />
                </LinearLayout>

                <LinearLayout style="@style/DetailButtonStyle">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_sort_by_size" />
                    <TextView style="@style/DetailTextStyle" android:text="Bağla" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/mainToolbar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="#1A1A1A"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout style="@style/MainMenuItemStyle" android:orientation="vertical">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/navigation_empty_icon" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Araçlar" android:textColor="#FFF" android:textSize="10sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnVertexMode"
                style="@style/MainMenuItemStyle"
                android:src="@android:drawable/presence_online" /> <ImageButton android:id="@+id/btnEdgeMode" style="@style/MainMenuItemStyle" android:src="@android:drawable/ic_menu_edit" />
            <ImageButton android:id="@+id/btnFaceMode" style="@style/MainMenuItemStyle" android:src="@android:drawable/ic_menu_gallery" />
            <ImageButton android:id="@+id/btnObjectMode" style="@style/MainMenuItemStyle" android:src="@android:drawable/ic_menu_help" />

        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
                    
